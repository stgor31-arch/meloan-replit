NODE_ENV=production
PORT=5000

# PostgreSQL
DATABASE_URL=postgresql://meloan:CHANGE_ME@127.0.0.1:5432/meloan

# Generate with: openssl rand -base64 32
SESSION_SECRET=CHANGE_ME

# Telegram Login Widget
TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_BOT_USERNAME=meloan_auth_bot

# Web Push / PWA notifications. Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=CHANGE_ME
VAPID_PRIVATE_KEY=CHANGE_ME

# Optional OAuth providers
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
VK_CLIENT_ID=

# Replit OIDC is disabled on a normal VPS. Leave empty for the Russian production deployment.
REPL_ID=
ISSUER_URL=
